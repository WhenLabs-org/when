{
  "name": "whenlabs-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "WhenLabs developer toolkit — monorepo for the @whenlabs/* packages",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "dev": "pnpm -r --parallel dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "engines": {
    "node": ">=20.12",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.0.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "onnxruntime-node",
      "protobufjs",
      "sharp"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
