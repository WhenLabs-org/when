{
  "name": "@whenlabs/aware",
  "version": "1.0.1",
  "description": "Auto-detect your stack, generate and sync AI context files (CLAUDE.md, .cursorrules, copilot-instructions.md, AGENTS.md)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "aware": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "claude",
    "cursor",
    "copilot",
    "ai",
    "context",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WhenLabs-org/when.git",
    "directory": "packages/aware"
  },
  "homepage": "https://github.com/WhenLabs-org/when/tree/main/packages/aware",
  "engines": {
    "node": ">=20.12"
  },
  "dependencies": {
    "@whenlabs/core": "workspace:^",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0",
    "toml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
