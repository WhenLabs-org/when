{
  "name": "@whenlabs/envalid",
  "version": "1.0.0",
  "description": "Type safety for .env files",
  "type": "module",
  "bin": {
    "envalid": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "env",
    "dotenv",
    "schema",
    "validator",
    "cli",
    "type-safety"
  ],
  "author": "WhenLabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/WhenLabs-org/when.git",
    "directory": "packages/envalid"
  },
  "homepage": "https://github.com/WhenLabs-org/when/tree/main/packages/envalid",
  "bugs": {
    "url": "https://github.com/WhenLabs-org/when/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@whenlabs/core": "workspace:^",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "dotenv": "^17.4.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
