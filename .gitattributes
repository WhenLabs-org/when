# Keep golden-file fixtures byte-identical across OSes. Without this,
# git's autocrlf on Windows checks them out with \r\n and the generator,
# which always writes \n, fails the byte-for-byte equality test.
*.golden.md text eol=lf

# Tell GitHub's Linguist that these paths are generated, not hand-written.
# They'll stop counting toward language stats, the Pulse / Code Frequency
# graphs, and Contributions. Source remains tracked; only the accounting
# changes.

# Pre-bundled output for the @whenlabs/stale GitHub Action (~11MB).
# Must be committed so the Action can run, but is produced by tsup from src/.
packages/stale/dist/action/** linguist-generated=true

# Lockfile: machine-managed, high churn.
pnpm-lock.yaml linguist-generated=true

# aware state + AI-context files — regenerated by `aware sync`.
.aware.json linguist-generated=true
CLAUDE.md linguist-generated=true
AGENTS.md linguist-generated=true
.github/copilot-instructions.md linguist-generated=true

# Demo fixtures and per-package test fixtures — inputs to scanners, not source.
demos/sample/** linguist-generated=true
packages/aware/tests/fixtures/** linguist-generated=true
packages/vow/tests/integration/fixtures/** linguist-generated=true
packages/envalid/tests/fixtures/** linguist-generated=true
packages/stale/tests/fixtures/** linguist-generated=true
packages/berth/tests/fixtures/** linguist-generated=true
