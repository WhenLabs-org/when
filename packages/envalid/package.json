{
  "name": "@whenlabs/envalid",
  "version": "0.3.0",
  "description": "Type safety for .env files",
  "type": "module",
  "bin": {
    "envalid": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/adapters/express.d.ts",
      "import": "./dist/adapters/express.js"
    },
    "./fastify": {
      "types": "./dist/adapters/fastify.d.ts",
      "import": "./dist/adapters/fastify.js"
    },
    "./nextjs": {
      "types": "./dist/adapters/nextjs.d.ts",
      "import": "./dist/adapters/nextjs.js"
    },
    "./nestjs": {
      "types": "./dist/adapters/nestjs.d.ts",
      "import": "./dist/adapters/nestjs.js"
    },
    "./vite": {
      "types": "./dist/adapters/vite.d.ts",
      "import": "./dist/adapters/vite.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "scripts",
    "action.yml"
  ],
  "keywords": [
    "env",
    "dotenv",
    "schema",
    "validator",
    "cli",
    "type-safety"
  ],
  "author": "WhenLabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/WhenLabs-org/envalid.git"
  },
  "homepage": "https://github.com/WhenLabs-org/envalid",
  "bugs": {
    "url": "https://github.com/WhenLabs-org/envalid/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@whenlabs/core": "workspace:^",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "dotenv": "^17.4.2",
    "inquirer": "^13.4.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
